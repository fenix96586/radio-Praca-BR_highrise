# ====== CONFIGURAÇÕES GERAIS ======
NODE_ENV=production
PORT=3000

# ====== BANCO DE DADOS ======
DATABASE_URL=sqlite:///database/radio.db
REDIS_URL=redis://localhost:6379

# ====== SERVIDOR DE STREAMING ======
STREAM_HOST=https://yourdomain.com
STREAM_PORT=3000
STREAM_PATH=/api/stream

# ====== ARMAZENAMENTO ======
STORAGE_PATH=./storage/music
MAX_LIBRARY_SIZE=500
MAX_UPLOAD_SIZE=100MB
MAX_FILES_PER_UPLOAD=50

# ====== HIGHRISE BOT ======
HIGHRISE_BOT_TOKEN=your_bot_token_here
HIGHRISE_ROOM_ID=your_room_id_here

# ====== YOUTUBE DOWNLOADER ======
YOUTUBE_DOWNLOADER_ENABLED=true
YOUTUBE_MAX_PLAYLIST_SIZE=100
YOUTUBE_TIMEOUT=300000

# ====== SEGURANÇA ======
JWT_SECRET=your_jwt_secret_key_here
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ====== CORS ======
CORS_ORIGIN=https://yourdomain.com
